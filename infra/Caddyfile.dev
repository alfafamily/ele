:80

encode gzip

# Ограничение доступа по IP — см. подробный комментарий в
# infra/Caddyfile (прод). Здесь то же самое, чтобы фичу можно было проверить
# в dev через docker compose, не только в проде.
forward_auth backend:8000 {
	uri /api/internal/ip-check/
}

handle /api/* {
	reverse_proxy backend:8000
}

# B9: служебная Django-админка (доступ гейтит сам backend). В dev статику
# админки (CSS/JS) при DEBUG раздаёт runserver, поэтому /static/* тоже ведём на
# backend, а не в SPA-fallback.
@django_admin path /django_admin /django_admin/*
handle @django_admin {
	reverse_proxy backend:8000
}

handle /static/* {
	reverse_proxy backend:8000
}

# Резервные копии содержат хэши паролей и все бизнес-данные —
# отдаются только через авторизованный /api/backup/<id>/download/,
# не статикой. Блок должен идти раньше общего /media/*.
handle /media/backups/* {
	respond 403
}

# В dev Django сам раздаёт media при DEBUG=True (config/urls.py) — нужно
# только доводить запрос до backend, а не отдавать SPA fallback.
handle /media/* {
	reverse_proxy backend:8000
}

handle {
	reverse_proxy frontend:5173
}
