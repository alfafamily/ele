{$SITE_ADDRESS}

encode gzip

# Ограничение доступа по IP — блокирует ВСЕ страницы сервиса,
# включая форму логина и саму SPA-оболочку, не только вызовы API: в проде
# Django не отдаёт фронтенд напрямую (это делает контейнер frontend), поэтому
# проверка должна стоять здесь, перед всеми handle-блоками, а не в Django-
# миддлваре. Пустой allowlist (по умолчанию) — эндпоинт всегда пропускает.
# Самоблокировка администратора снимается на сервере: `docker compose exec
# backend python manage.py reset_ip_allowlist`.
forward_auth backend:8000 {
	uri /api/internal/ip-check/
}

handle /api/* {
	reverse_proxy backend:8000
}

# Резервные копии содержат хэши паролей и все бизнес-данные —
# отдаются только через авторизованный /api/backup/<id>/download/,
# не статикой. Блок должен идти раньше общего /media/*.
handle /media/backups/* {
	respond 403
}

handle /static/* {
	root * /srv
	file_server
}

handle /media/* {
	root * /srv
	# Пользовательские файлы отдаются inline (просмотрщик реквизитов,/),
	# поэтому нейтрализуем возможный stored XSS: CSP sandbox лишает любой
	# html/js-документ прав на исполнение скриптов и собственный origin, не
	# мешая показу изображений. nosniff — против MIME-подмены.
	#
	# Исключение — PDF: nosniff гарантирует, что .pdf отдаётся как
	# application/pdf и не может исполниться как html, поэтому sandbox для него
	# не нужен по безопасности, а вот встроенный PDF-просмотрщик Chrome он
	# ломает («Эта страница была заблокирована браузером Chrome»). Поэтому CSP
	# sandbox ставим всем, КРОМЕ *.pdf.
	@notpdf not path *.pdf
	header @notpdf Content-Security-Policy "sandbox"
	header X-Content-Type-Options "nosniff"
	file_server
}

handle {
	reverse_proxy frontend:80
}
