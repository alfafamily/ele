# Скопировать в .env и заполнить. .env не коммитится (см. .gitignore).
# Секреты живут только здесь, не в БД/интерфейсе. Приложение НИКОГДА не пишет в
# этот файл — мастер первичной настройки только читает уже заданные значения и
# тестирует подключение (S3/почта/капча/Яндекс ID). Если тест не проходит —
# поправьте .env и перезапустите `docker compose up -d` (переменные читаются
# один раз при старте контейнера).

# --- Django ---
DJANGO_SECRET_KEY=changeme-generate-a-real-random-secret-key
# Только для docker-compose.prod.yml (dev использует ALLOWED_HOSTS=["*"]):
DJANGO_ALLOWED_HOSTS=ele.example.com
CSRF_TRUSTED_ORIGINS=https://ele.example.com
# Публичный адрес инстанса (SPA и API на одном домене) — абсолютные ссылки в
# письмах, redirect_uri для Яндекс ID OAuth. В dev можно оставить как есть.
SITE_URL=http://localhost
DEFAULT_FROM_EMAIL=ELE <no-reply@ele.example.com>

# --- PostgreSQL ---
POSTGRES_USER=ele
POSTGRES_PASSWORD=changeme
POSTGRES_DB=ele

# --- Caddy (только прод, docker-compose.prod.yml) ---
# Реальный домен — Caddy сам получит сертификат Let's Encrypt.
SITE_ADDRESS=ele.example.com

# --- Email (SMTP) ---
# В dev всегда используется mailpit, значения ниже не читаются. В проде —
# опционально: пусто = приложение стартует, но письма никуда не уходят (мастер
# первичной настройки предупредит и не даст пройти проверку почты).
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
# Шифрование: порт 587 — STARTTLS (EMAIL_USE_TLS=true), порт 465 — implicit SSL
# (EMAIL_USE_SSL=true). Для порта 465 SSL включается автоматически, даже если
# EMAIL_USE_SSL не задан. Одновременно включать оба нельзя; если задан SSL, он
# имеет приоритет и TLS выключается автоматически.
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
# Таймаут соединения с SMTP, сек (по умолчанию 10) — чтобы недоступный SMTP не
# «вешал» отправку писем, а быстро возвращал понятную ошибку.
EMAIL_TIMEOUT=10

# --- Первый администратор (создаётся автоматически при первом старте) ---
ELE_ADMIN_EMAIL=admin@example.com
ELE_ADMIN_PASSWORD=changeme

# --- Хранилище файлов ---
# ELE_STORAGE_MODE=local | s3. Мастер первичной настройки показывает эти
# значения только для просмотра и тестирует подключение — ввода через UI нет.
ELE_STORAGE_MODE=local
S3_ENDPOINT=
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=

# --- Яндекс SmartCaptcha ---
# Пусто = капча выключена, лимит попыток + блокировка продолжают работать.
YANDEX_SMARTCAPTCHA_SITE_KEY=
YANDEX_SMARTCAPTCHA_SECRET_KEY=

# --- Яндекс ID OAuth ---
# Пусто = кнопка "Войти через Яндекс ID" не отображается.
YANDEX_ID_CLIENT_ID=
YANDEX_ID_CLIENT_SECRET=
